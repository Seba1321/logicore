# ====================================================================
# Methodical — Variables de entorno
# Copia este archivo a `.env` y rellena con tus credenciales.
# ====================================================================

# --- Supabase (Portal de clientes) ---
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=tu-publishable-key
# Alternativa si todavía no migraste a publishable keys:
VITE_SUPABASE_ANON_KEY=tu-anon-public-key

# --- EmailJS (Formulario de contacto del landing) ---
# Crea una cuenta gratuita en https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx

# ====================================================================
# Sólo para scripts locales (no se exponen en el frontend).
# No commitear valores reales.
# ====================================================================
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
SUPABASE_BPMN_BUCKET=bpmn
