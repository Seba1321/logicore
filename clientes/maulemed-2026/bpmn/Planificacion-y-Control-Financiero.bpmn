<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_mauled_pcf" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <bpmn:collaboration id="Collaboration_pcf">
    <bpmn:participant id="Part_main" name="Administración y Finanzas — MauleMed" processRef="Process_main" />
    <bpmn:participant id="Part_ris" name="RIS/PACS" processRef="Process_ris" />
    <bpmn:participant id="Part_banco" name="Banco" processRef="Process_banco" />
    <bpmn:messageFlow id="mf1" name="Informe de caja" sourceRef="Part_ris" targetRef="T_cerrarCaja" />
    <bpmn:messageFlow id="mf2" name="Nómina cobranza Fonasa" sourceRef="Part_ris" targetRef="T_facturacion" />
    <bpmn:messageFlow id="mf3" name="Cartolas bancarias" sourceRef="Part_banco" targetRef="C_concBancaria" />
    <bpmn:textAnnotation id="Ann_ing">
      <bpmn:text>Ingresos se controlan principalmente vía RIS/PACS (por sucursal y prestación). La facturación es cruzada, una factura puede incluir varias sucursales / razones sociales. RIS/PACS no siempre refleja descuentos, migración a nuevo sistema (codesud)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ann_cob">
      <bpmn:text>Fonasa: sin mayor problema. Instituciones: cobran con bono / orden manual y lógica propia. Si los bonos del sistema no cuadran con los físicos, se corrigen y corroboran.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ann_comp">
      <bpmn:text>Compras a veces decididas sin verificación de presupuesto (decisión médica). No hay iconocimiento de inventario, insumos se reciben y despachan centralizadamente.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ann_flujo">
      <bpmn:text>Se arma manualmente en Excel, por razón social / sucursal. Ningún sistema entrega los datos automáticamente. El sistema contable no está separado por centro de costo.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="As_Ann_cob" associationDirection="None" sourceRef="T_verificarBonos" targetRef="Ann_cob" />
    <bpmn:association id="As_Ann_flujo" associationDirection="None" sourceRef="J_construirFlujo" targetRef="Ann_flujo" />
    <bpmn:association id="As_Ann_comp" associationDirection="None" sourceRef="T_recibFact" targetRef="Ann_comp" />
  </bpmn:collaboration>
  <bpmn:process id="Process_main" isExecutable="false">
    <bpmn:laneSet id="LaneSet_main">
      <bpmn:lane id="Lane_con" name="Contabilidad (Contadora / Asistente)">
        <bpmn:flowNodeRef>C_regVentas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>C_regPago</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>C_concBancaria</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>M_egresos</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_jef" name="Jefatura de Administración y Finanzas (Liz Bravo)">
        <bpmn:flowNodeRef>J_revisarFact</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_revVentas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>J_consolIngresos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>J_revObligaciones</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>J_costosFijos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>J_gastosVar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>J_construirFlujo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvt</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_tes" name="Tesorería">
        <bpmn:flowNodeRef>T_cerrarCaja</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_cobranza</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_verificarBonos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>M_cobranza</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_recibFact</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_vistoBueno</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_gestCorr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_aprobarPago</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_pagoAprob</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_emitirCheque</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_retenerPago</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_facturacion</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:userTask id="T_cerrarCaja" name="Cerrar caja y generar informe de caja">
      <bpmn:incoming>f02</bpmn:incoming>
      <bpmn:outgoing>f04</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gw_cobranza" name="¿Cobranza a Fonasa o a Isapre?">
      <bpmn:incoming>f06</bpmn:incoming>
      <bpmn:outgoing>f07</bpmn:outgoing>
      <bpmn:outgoing>f08</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="T_verificarBonos" name="Verificar bonos manuales (sistema vs. físico)">
      <bpmn:incoming>f08</bpmn:incoming>
      <bpmn:outgoing>f09</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="M_cobranza">
      <bpmn:incoming>f07</bpmn:incoming>
      <bpmn:incoming>f09</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="J_revisarFact" name="Revisar facturación y cobranza">
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gw_revVentas" name="¿Facturación y cobranza correctas?">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="C_regVentas" name="Registrar ventas en contabilidad">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f14</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="T_recibFact" name="Recibir requerimiento / factura de compra">
      <bpmn:incoming>f03</bpmn:incoming>
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f15</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gw_vistoBueno" name="¿Factura con visto bueno de Tesorería?">
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
      <bpmn:outgoing>f17</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="T_gestCorr" name="Gestionar corrección / rechazo">
      <bpmn:incoming>f17</bpmn:incoming>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="T_aprobarPago" name="Aprobar pago (Tesorería + Contabilidad)">
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f19</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gw_pagoAprob" name="¿Pago aprobado?">
      <bpmn:incoming>f19</bpmn:incoming>
      <bpmn:outgoing>f20</bpmn:outgoing>
      <bpmn:outgoing>f21</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="T_emitirCheque" name="Emitir pago">
      <bpmn:incoming>f20</bpmn:incoming>
      <bpmn:outgoing>f22</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="C_regPago" name="Registrar pago">
      <bpmn:incoming>f22</bpmn:incoming>
      <bpmn:outgoing>f23</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="C_concBancaria" name="Realizar conciliación bancaria">
      <bpmn:incoming>f23</bpmn:incoming>
      <bpmn:outgoing>f24</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Gw_join">
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:incoming>f26</bpmn:incoming>
      <bpmn:outgoing>f27</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="J_consolIngresos" name="Consolidar ingresos desde RIS/PACS">
      <bpmn:incoming>f27</bpmn:incoming>
      <bpmn:outgoing>f28</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="J_revObligaciones" name="Revisar obligaciones">
      <bpmn:incoming>f28</bpmn:incoming>
      <bpmn:outgoing>f29</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="J_costosFijos" name="Incorporar costos fijos">
      <bpmn:incoming>f29</bpmn:incoming>
      <bpmn:outgoing>f30</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="J_gastosVar" name="Incorporar gastos generales variables">
      <bpmn:incoming>f30</bpmn:incoming>
      <bpmn:outgoing>f31</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="J_construirFlujo" name="Construir flujo de caja (Excel)">
      <bpmn:incoming>f31</bpmn:incoming>
      <bpmn:outgoing>f32</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvt" name="Flujo de caja consolidado y disponible para control">
      <bpmn:incoming>f32</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:parallelGateway id="Gw_split">
      <bpmn:incoming>f01</bpmn:incoming>
      <bpmn:outgoing>f02</bpmn:outgoing>
      <bpmn:outgoing>f03</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:startEvent id="StartEvt" name="Inicio: hora de cierre / fin de jornada">
      <bpmn:outgoing>f01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="T_retenerPago" name="Retener pago">
      <bpmn:incoming>f21</bpmn:incoming>
      <bpmn:outgoing>f25</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="M_egresos">
      <bpmn:incoming>f24</bpmn:incoming>
      <bpmn:incoming>f25</bpmn:incoming>
      <bpmn:outgoing>f26</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="f02" sourceRef="Gw_split" targetRef="T_cerrarCaja" />
    <bpmn:sequenceFlow id="f04" sourceRef="T_cerrarCaja" targetRef="T_facturacion" />
    <bpmn:sequenceFlow id="f13" name="No" sourceRef="Gw_revVentas" targetRef="T_facturacion" />
    <bpmn:sequenceFlow id="f06" sourceRef="T_facturacion" targetRef="Gw_cobranza" />
