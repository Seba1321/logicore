<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_Financiero" targetNamespace="http://maulemed.cl/bpmn">
  <bpmn:collaboration id="Collaboration_Fin">
    <bpmn:participant id="Participant_Caja" name="Flujo de caja diario (ingresos)" processRef="Process_Caja" />
    <bpmn:participant id="Participant_Pagos" name="Gestión de compras y pagos (egresos)" processRef="Process_Pagos" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Caja" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Process_Caja">
      <bpmn:lane id="L_RIS" name="Sistema RIS/PACS">
        <bpmn:flowNodeRef>p1_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p1_inf</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_TES" name="Tesorería / Facturación (Gabriela Morales)">
        <bpmn:flowNodeRef>p1_recibe</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p1_recaud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p1_fact</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p1_gc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p1_verif</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_LIZ" name="Administración y Finanzas (Liz Bravo)">
        <bpmn:flowNodeRef>p1_rev</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p1_consol</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p1_end</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_CON" name="Contabilidad (Elvira Rojas / Maribel Escobar)">
        <bpmn:flowNodeRef>p1_con</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="p1_start" name="Atención registrada en RIS/PACS">
      <bpmn:outgoing>q1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="p1_inf" name="Generar informe de caja y de producción">
      <bpmn:incoming>q1</bpmn:incoming>
      <bpmn:outgoing>q2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="p1_recibe" name="Recibir informe de caja (por empresa)">
      <bpmn:incoming>q2</bpmn:incoming>
      <bpmn:outgoing>q3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="p1_recaud" name="Registrar recaudación (ingresos)">
      <bpmn:incoming>q3</bpmn:incoming>
      <bpmn:outgoing>q4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="p1_fact" name="Emitir nómina y facturar (Fonasa / instituciones)">
      <bpmn:incoming>q4</bpmn:incoming>
      <bpmn:outgoing>q5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="p1_gc" name="¿Diferencias en bonos u órdenes?">
      <bpmn:incoming>q5</bpmn:incoming>
      <bpmn:outgoing>q6</bpmn:outgoing>
      <bpmn:outgoing>q7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="p1_verif" name="Verificar y corregir cobranza">
      <bpmn:incoming>q6</bpmn:incoming>
      <bpmn:outgoing>q8</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="p1_rev" name="Revisar facturación y cobranza">
      <bpmn:incoming>q7</bpmn:incoming>
      <bpmn:incoming>q8</bpmn:incoming>
      <bpmn:outgoing>q9</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="p1_con" name="Registrar venta en contabilidad">
      <bpmn:incoming>q9</bpmn:incoming>
      <bpmn:outgoing>q10</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="p1_consol" name="Consolidar flujo de caja del día">
      <bpmn:incoming>q10</bpmn:incoming>
      <bpmn:outgoing>q11</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="p1_end" name="Caja consolidada para control y decisiones">
      <bpmn:incoming>q11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="q1" sourceRef="p1_start" targetRef="p1_inf" />
    <bpmn:sequenceFlow id="q2" sourceRef="p1_inf" targetRef="p1_recibe" />
    <bpmn:sequenceFlow id="q3" sourceRef="p1_recibe" targetRef="p1_recaud" />
    <bpmn:sequenceFlow id="q4" sourceRef="p1_recaud" targetRef="p1_fact" />
    <bpmn:sequenceFlow id="q5" sourceRef="p1_fact" targetRef="p1_gc" />
    <bpmn:sequenceFlow id="q6" sourceRef="p1_gc" targetRef="p1_verif" name="Sí" />
    <bpmn:sequenceFlow id="q7" sourceRef="p1_gc" targetRef="p1_rev" name="No" />
    <bpmn:sequenceFlow id="q8" sourceRef="p1_verif" targetRef="p1_rev" />
    <bpmn:sequenceFlow id="q9" sourceRef="p1_rev" targetRef="p1_con" />
    <bpmn:sequenceFlow id="q10" sourceRef="p1_con" targetRef="p1_consol" />
    <bpmn:sequenceFlow id="q11" sourceRef="p1_consol" targetRef="p1_end" />
  </bpmn:process>
  <bpmn:process id="Process_Pagos" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Process_Pagos">
      <bpmn:lane id="L_DOC" name="Doctores / Gerencia">
        <bpmn:flowNodeRef>p2_decide</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_TES2" name="Tesorería / Compras (Gabriela Morales)">
        <bpmn:flowNodeRef>p2_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p2_gtipo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p2_orden</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p2_fact</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p2_vb</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p2_gm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p2_cheque</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p2_end</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_LIZ2" name="Administración y Finanzas (Liz Bravo)">
        <bpmn:flowNodeRef>p2_fijo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p2_aprob</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_CON2" name="Contabilidad (Elvira Rojas / Maribel Escobar)">
        <bpmn:flowNodeRef>p2_regc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p2_concil</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="p2_start" name="Egreso a gestionar">
      <bpmn:outgoing>r1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="p2_gtipo" name="Tipo de egreso">
      <bpmn:incoming>r1</bpmn:incoming>
      <bpmn:outgoing>r2</bpmn:outgoing>
      <bpmn:outgoing>r3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="p2_decide" name="Decidir compra">
      <bpmn:incoming>r2</bpmn:incoming>
      <bpmn:outgoing>r4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="p2_orden" name="Emitir orden de compra">
      <bpmn:incoming>r4</bpmn:incoming>
      <bpmn:outgoing>r5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="p2_fact" name="Recibir factura del proveedor">
      <bpmn:incoming>r5</bpmn:incoming>
      <bpmn:outgoing>r6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="p2_vb" name="Dar visto bueno a la factura">
      <bpmn:incoming>r6</bpmn:incoming>
      <bpmn:outgoing>r7</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="p2_regc" name="Registrar compra en contabilidad">
      <bpmn:incoming>r7</bpmn:incoming>
      <bpmn:outgoing>r8</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="p2_fijo" name="Identificar costo fijo o crédito (cartola del banco)">
      <bpmn:incoming>r3</bpmn:incoming>
      <bpmn:outgoing>r9</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="p2_gm">
      <bpmn:incoming>r8</bpmn:incoming>
      <bpmn:incoming>r9</bpmn:incoming>
      <bpmn:outgoing>r10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="p2_aprob" name="Aprobar pago">
      <bpmn:incoming>r10</bpmn:incoming>
      <bpmn:outgoing>r11</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="p2_cheque" name="Emitir pago con cheque">
      <bpmn:incoming>r11</bpmn:incoming>
      <bpmn:outgoing>r12</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="p2_concil" name="Registrar pago y conciliación bancaria">
      <bpmn:incoming>r12</bpmn:incoming>
      <bpmn:outgoing>r13</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="p2_end" name="Egreso pagado y conciliado">
      <bpmn:incoming>r13</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="r1" sourceRef="p2_start" targetRef="p2_gtipo" />
    <bpmn:sequenceFlow id="r2" sourceRef="p2_gtipo" targetRef="p2_decide" name="Compra / insumo" />
    <bpmn:sequenceFlow id="r3" sourceRef="p2_gtipo" targetRef="p2_fijo" name="Costo fijo / crédito" />
    <bpmn:sequenceFlow id="r4" sourceRef="p2_decide" targetRef="p2_orden" />
    <bpmn:sequenceFlow id="r5" sourceRef="p2_orden" targetRef="p2_fact" />
    <bpmn:sequenceFlow id="r6" sourceRef="p2_fact" targetRef="p2_vb" />
    <bpmn:sequenceFlow id="r7" sourceRef="p2_vb" targetRef="p2_regc" />
    <bpmn:sequenceFlow id="r8" sourceRef="p2_regc" targetRef="p2_gm" />
    <bpmn:sequenceFlow id="r9" sourceRef="p2_fijo" targetRef="p2_gm" />
    <bpmn:sequenceFlow id="r10" sourceRef="p2_gm" targetRef="p2_aprob" />
    <bpmn:sequenceFlow id="r11" sourceRef="p2_aprob" targetRef="p2_cheque" />
    <bpmn:sequenceFlow id="r12" sourceRef="p2_cheque" targetRef="p2_concil" />
    <bpmn:sequenceFlow id="r13" sourceRef="p2_concil" targetRef="p2_end" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Fin">
    <bpmndi:BPMNPlane id="BPMNPlane_Fin" bpmnElement="Collaboration_Fin">
