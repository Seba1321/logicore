        <di:waypoint x="1390" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="q9_di" bpmnElement="q9">
        <di:waypoint x="1530" y="380" />
        <di:waypoint x="1550" y="380" />
        <di:waypoint x="1550" y="500" />
        <di:waypoint x="1570" y="500" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="q10_di" bpmnElement="q10">
        <di:waypoint x="1710" y="500" />
        <di:waypoint x="1730" y="500" />
