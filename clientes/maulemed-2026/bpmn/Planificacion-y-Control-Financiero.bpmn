      <bpmndi:BPMNShape id="L_DOC_di" bpmnElement="L_DOC" isHorizontal="true">
        <dc:Bounds x="190" y="620" width="2100" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_TES2_di" bpmnElement="L_TES2" isHorizontal="true">
        <dc:Bounds x="190" y="740" width="2100" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_LIZ2_di" bpmnElement="L_LIZ2" isHorizontal="true">
