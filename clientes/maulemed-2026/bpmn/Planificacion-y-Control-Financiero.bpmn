    <bpmn:sequenceFlow id="f11" sourceRef="J_revisarFact" targetRef="Gw_revVentas" />
    <bpmn:sequenceFlow id="f12" name="Sí" sourceRef="Gw_revVentas" targetRef="C_regVentas" />
    <bpmn:sequenceFlow id="f14" sourceRef="C_regVentas" targetRef="Gw_join" />
    <bpmn:sequenceFlow id="f03" sourceRef="Gw_split" targetRef="T_recibFact" />
    <bpmn:sequenceFlow id="f18" sourceRef="T_gestCorr" targetRef="T_recibFact" />
    <bpmn:sequenceFlow id="f15" sourceRef="T_recibFact" targetRef="Gw_vistoBueno" />
    <bpmn:sequenceFlow id="f16" name="Sí" sourceRef="Gw_vistoBueno" targetRef="T_aprobarPago" />
    <bpmn:sequenceFlow id="f17" name="No" sourceRef="Gw_vistoBueno" targetRef="T_gestCorr" />
    <bpmn:sequenceFlow id="f19" sourceRef="T_aprobarPago" targetRef="Gw_pagoAprob" />
    <bpmn:sequenceFlow id="f20" name="Sí" sourceRef="Gw_pagoAprob" targetRef="T_emitirCheque" />
    <bpmn:sequenceFlow id="f21" name="No" sourceRef="Gw_pagoAprob" targetRef="T_retenerPago" />
    <bpmn:sequenceFlow id="f22" sourceRef="T_emitirCheque" targetRef="C_regPago" />
    <bpmn:sequenceFlow id="f23" sourceRef="C_regPago" targetRef="C_concBancaria" />
    <bpmn:sequenceFlow id="f24" sourceRef="C_concBancaria" targetRef="M_egresos" />
    <bpmn:sequenceFlow id="f26" sourceRef="M_egresos" targetRef="Gw_join" />
    <bpmn:sequenceFlow id="f27" sourceRef="Gw_join" targetRef="J_consolIngresos" />
    <bpmn:sequenceFlow id="f28" sourceRef="J_consolIngresos" targetRef="J_revObligaciones" />
    <bpmn:sequenceFlow id="f29" sourceRef="J_revObligaciones" targetRef="J_costosFijos" />
    <bpmn:sequenceFlow id="f30" sourceRef="J_costosFijos" targetRef="J_gastosVar" />
    <bpmn:sequenceFlow id="f31" sourceRef="J_gastosVar" targetRef="J_construirFlujo" />
    <bpmn:sequenceFlow id="f32" sourceRef="J_construirFlujo" targetRef="EndEvt" />
    <bpmn:sequenceFlow id="f01" sourceRef="StartEvt" targetRef="Gw_split" />
    <bpmn:sequenceFlow id="f25" sourceRef="T_retenerPago" targetRef="M_egresos" />
    <bpmn:userTask id="T_facturacion" name="Realizar facturación según nómina Fonasa">
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:incoming>f04</bpmn:incoming>
      <bpmn:outgoing>f06</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:association id="As_Ann_ing" associationDirection="None" sourceRef="T_facturacion" targetRef="Ann_ing" />
  </bpmn:process>
