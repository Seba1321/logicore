      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="p2_end_di" bpmnElement="p2_end" color:background-color="#f8e3e3" color:border-color="#b35454">
        <dc:Bounds x="2162" y="782" width="36" height="36" />
      </bpmndi:BPMNShape>
