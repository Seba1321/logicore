<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_CicloVida" targetNamespace="http://maulemed.cl/bpmn">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Gestión del Ciclo de Vida del Personal" processRef="Process_1" />
    <bpmn:participant id="Participant_2" name="Cierre mensual de asistencia (insumo de remuneraciones)" processRef="Process_2" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Process_1">
      <bpmn:lane id="Lane_MED" name="Médicos responsables (Dr. Retamal / Dr. Valenzuela)">
        <bpmn:flowNodeRef>entr_clin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>decision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>firma_med</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_RHH" name="Encargada de RR.HH. (Patricia Lobos)">
        <bpmn:flowNodeRef>start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>publicar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>recibir_cv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>entrevista</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g3m</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>decidir</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ficha</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>contrato</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>mutual</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>incorporar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>archivar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>bA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>bB</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>bC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>bD</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g5m</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>carta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>recopilar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>finiquito</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>pagar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_REM" name="Remuneraciones / Administración">
        <bpmn:flowNodeRef>entr_adm</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_TRA" name="Trabajador / Candidato">
        <bpmn:flowNodeRef>firma1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ratificar</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start" name="Necesidad de cubrir un cargo">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="publicar" name="Publicar oferta laboral (Bolsa Nacional de Empleo y contactos)">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="recibir_cv" name="Recibir y filtrar CV por perfil">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="g1" name="¿Candidatos idóneos?">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="entrevista" name="Realizar entrevista inicial">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="g3" name="Tipo de cargo">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="entr_clin" name="Realizar entrevista final clínica">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="entr_adm" name="Realizar entrevista final administrativa">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="g3m">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="decidir" name="Decidir contratación">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="g4" name="¿Candidato seleccionado?">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
      <bpmn:outgoing>f14</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="ficha" name="Confeccionar ficha e ingresar a Fontana">
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f15</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="contrato" name="Elaborar contrato, anexos y pacto de HHEE">
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="mutual" name="Entregar mutualidad y reglamento">
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f17</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:manualTask id="firma1" name="Firmar contrato y anexos">
      <bpmn:incoming>f17</bpmn:incoming>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:userTask id="incorporar" name="Incorporar al reloj control y asignar tutor">
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f19</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:manualTask id="archivar" name="Archivar por sociedad">
      <bpmn:incoming>f19</bpmn:incoming>
      <bpmn:outgoing>f20</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:exclusiveGateway id="g5" name="Gestión durante la permanencia">
      <bpmn:incoming>f20</bpmn:incoming>
      <bpmn:incoming>f30</bpmn:incoming>
      <bpmn:outgoing>f21</bpmn:outgoing>
      <bpmn:outgoing>f22</bpmn:outgoing>
      <bpmn:outgoing>f23</bpmn:outgoing>
      <bpmn:outgoing>f24</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="bA" name="Autorizar permiso (previa cobertura)">
      <bpmn:incoming>f21</bpmn:incoming>
      <bpmn:outgoing>f25</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="bB" name="Autorizar feriado (saldo y cobertura)">
      <bpmn:incoming>f22</bpmn:incoming>
      <bpmn:outgoing>f26</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="bC" name="Ingresar licencia médica">
      <bpmn:incoming>f23</bpmn:incoming>
      <bpmn:outgoing>f27</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="bD" name="Elaborar anexo de traspaso">
      <bpmn:incoming>f24</bpmn:incoming>
      <bpmn:outgoing>f28</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="g5m">
      <bpmn:incoming>f25</bpmn:incoming>
      <bpmn:incoming>f26</bpmn:incoming>
      <bpmn:incoming>f27</bpmn:incoming>
      <bpmn:incoming>f28</bpmn:incoming>
      <bpmn:outgoing>f29</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="g6" name="¿Continúa la relación?">
      <bpmn:incoming>f29</bpmn:incoming>
      <bpmn:outgoing>f30</bpmn:outgoing>
      <bpmn:outgoing>f31</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="decision" name="Determinar término y causal">
      <bpmn:incoming>f31</bpmn:incoming>
      <bpmn:outgoing>f32</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="carta" name="Elaborar y fundamentar carta de aviso">
      <bpmn:incoming>f32</bpmn:incoming>
      <bpmn:outgoing>f33</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="recopilar" name="Recopilar antecedentes (AFC, historial, feriados)">
      <bpmn:incoming>f33</bpmn:incoming>
      <bpmn:outgoing>f34</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="finiquito" name="Calcular finiquito y revisar datos">
      <bpmn:incoming>f34</bpmn:incoming>
      <bpmn:outgoing>f35</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="firma_med" name="Gestionar firma del médico">
      <bpmn:incoming>f35</bpmn:incoming>
      <bpmn:outgoing>f36</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:manualTask id="ratificar" name="Ratificar finiquito ante ministro de fe">
      <bpmn:incoming>f36</bpmn:incoming>
      <bpmn:outgoing>f37</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:userTask id="pagar" name="Pagar y archivar finiquito">
      <bpmn:incoming>f37</bpmn:incoming>
      <bpmn:outgoing>f38</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="end" name="Trabajador desvinculado">
      <bpmn:incoming>f38</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="start" targetRef="publicar" />
    <bpmn:sequenceFlow id="f2" sourceRef="publicar" targetRef="recibir_cv" />
    <bpmn:sequenceFlow id="f3" sourceRef="recibir_cv" targetRef="g1" />
    <bpmn:sequenceFlow id="f4" sourceRef="g1" targetRef="entrevista" name="Sí" />
    <bpmn:sequenceFlow id="f5" sourceRef="g1" targetRef="publicar" name="No, republicar" />
    <bpmn:sequenceFlow id="f6" sourceRef="entrevista" targetRef="g3" />
    <bpmn:sequenceFlow id="f7" sourceRef="g3" targetRef="entr_clin" name="Clínico" />
    <bpmn:sequenceFlow id="f8" sourceRef="g3" targetRef="entr_adm" name="Administrativo" />
    <bpmn:sequenceFlow id="f9" sourceRef="entr_clin" targetRef="g3m" />
    <bpmn:sequenceFlow id="f10" sourceRef="entr_adm" targetRef="g3m" />
    <bpmn:sequenceFlow id="f11" sourceRef="g3m" targetRef="decidir" />
    <bpmn:sequenceFlow id="f12" sourceRef="decidir" targetRef="g4" />
    <bpmn:sequenceFlow id="f13" sourceRef="g4" targetRef="ficha" name="Sí" />
    <bpmn:sequenceFlow id="f14" sourceRef="g4" targetRef="publicar" name="No" />
    <bpmn:sequenceFlow id="f15" sourceRef="ficha" targetRef="contrato" />
    <bpmn:sequenceFlow id="f16" sourceRef="contrato" targetRef="mutual" />
    <bpmn:sequenceFlow id="f17" sourceRef="mutual" targetRef="firma1" />
    <bpmn:sequenceFlow id="f18" sourceRef="firma1" targetRef="incorporar" />
    <bpmn:sequenceFlow id="f19" sourceRef="incorporar" targetRef="archivar" />
    <bpmn:sequenceFlow id="f20" sourceRef="archivar" targetRef="g5" />
    <bpmn:sequenceFlow id="f21" sourceRef="g5" targetRef="bA" name="Permiso" />
    <bpmn:sequenceFlow id="f22" sourceRef="g5" targetRef="bB" name="Feriado / vacaciones" />
    <bpmn:sequenceFlow id="f23" sourceRef="g5" targetRef="bC" name="Licencia médica" />
    <bpmn:sequenceFlow id="f24" sourceRef="g5" targetRef="bD" name="Cambio contractual / traspaso" />
    <bpmn:sequenceFlow id="f25" sourceRef="bA" targetRef="g5m" />
    <bpmn:sequenceFlow id="f26" sourceRef="bB" targetRef="g5m" />
    <bpmn:sequenceFlow id="f27" sourceRef="bC" targetRef="g5m" />
    <bpmn:sequenceFlow id="f28" sourceRef="bD" targetRef="g5m" />
    <bpmn:sequenceFlow id="f29" sourceRef="g5m" targetRef="g6" />
    <bpmn:sequenceFlow id="f30" sourceRef="g6" targetRef="g5" name="Sí, continúa" />
    <bpmn:sequenceFlow id="f31" sourceRef="g6" targetRef="decision" name="No" />
    <bpmn:sequenceFlow id="f32" sourceRef="decision" targetRef="carta" />
    <bpmn:sequenceFlow id="f33" sourceRef="carta" targetRef="recopilar" />
    <bpmn:sequenceFlow id="f34" sourceRef="recopilar" targetRef="finiquito" />
    <bpmn:sequenceFlow id="f35" sourceRef="finiquito" targetRef="firma_med" />
    <bpmn:sequenceFlow id="f36" sourceRef="firma_med" targetRef="ratificar" />
    <bpmn:sequenceFlow id="f37" sourceRef="ratificar" targetRef="pagar" />
    <bpmn:sequenceFlow id="f38" sourceRef="pagar" targetRef="end" />
  </bpmn:process>
  <bpmn:process id="Process_2" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Process_2">
      <bpmn:lane id="Lane_RHH2" name="Encargada de RR.HH. (Patricia Lobos)">
        <bpmn:flowNodeRef>c_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>c_extra</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>c_gc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>c_corregir</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>c_valida</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>c_planilla</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>c_end</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_REM2" name="Remuneraciones / Administración">
        <bpmn:flowNodeRef>c_liq</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="c_start" name="Cierre mensual (día 24)">
      <bpmn:outgoing>p1</bpmn:outgoing>
      <bpmn:timerEventDefinition />
    </bpmn:startEvent>
    <bpmn:userTask id="c_extra" name="Extraer y revisar marcajes por empresa">
      <bpmn:incoming>p1</bpmn:incoming>
      <bpmn:incoming>p5</bpmn:incoming>
      <bpmn:outgoing>p2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="c_gc" name="¿Errores de marcaje?">
      <bpmn:incoming>p2</bpmn:incoming>
      <bpmn:outgoing>p3</bpmn:outgoing>
      <bpmn:outgoing>p4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="c_corregir" name="Corregir marcaje">
      <bpmn:incoming>p3</bpmn:incoming>
      <bpmn:outgoing>p5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="c_valida" name="Validar permisos/licencias y calcular HHEE">
      <bpmn:incoming>p4</bpmn:incoming>
      <bpmn:outgoing>p6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sendTask id="c_planilla" name="Consolidar y enviar planilla de HHEE">
      <bpmn:incoming>p6</bpmn:incoming>
      <bpmn:outgoing>p7</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="c_liq" name="Ingresar liquidaciones y gestionar firma">
      <bpmn:incoming>p7</bpmn:incoming>
      <bpmn:outgoing>p8</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="c_end" name="Remuneraciones procesadas">
      <bpmn:incoming>p8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="p1" sourceRef="c_start" targetRef="c_extra" />
    <bpmn:sequenceFlow id="p2" sourceRef="c_extra" targetRef="c_gc" />
    <bpmn:sequenceFlow id="p3" sourceRef="c_gc" targetRef="c_corregir" name="Sí" />
    <bpmn:sequenceFlow id="p4" sourceRef="c_gc" targetRef="c_valida" name="No" />
    <bpmn:sequenceFlow id="p5" sourceRef="c_corregir" targetRef="c_extra" />
    <bpmn:sequenceFlow id="p6" sourceRef="c_valida" targetRef="c_planilla" />
    <bpmn:sequenceFlow id="p7" sourceRef="c_planilla" targetRef="c_liq" />
    <bpmn:sequenceFlow id="p8" sourceRef="c_liq" targetRef="c_end" />
  </bpmn:process>
